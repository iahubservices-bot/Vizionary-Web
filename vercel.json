{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "ZAPIER_WEBHOOK_URL": "@zapier_webhook_url",
    "SMTP_USER": "@smtp_user",
    "SMTP_PASS": "@smtp_pass",
    "API_KEY": "@api_key"
  }
}